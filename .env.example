# .env.example — 실값 없음, 키 이름만 기재
# 복사: cp .env.example .env  후 실값 채우기

# --- STEP 001: LangSmith 관측 ---
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# --- STEP 001: OpenAI ---
OPENAI_API_KEY=

# --- STEP 001: Vector Store (Milvus) ---
MILVUS_HOST=
MILVUS_PORT=

# --- STEP 001: Redis ---
REDIS_URL=

# --- STEP 004: PostgreSQL ---
DATABASE_URL=

# --- STEP 005: LLM 설정 ---
# LLM_PROVIDER=mock  또는  LLM_PROVIDER=openai
LLM_PROVIDER=
LLM_MODEL=
LLM_TIMEOUT_SEC=
LLM_MAX_TOKENS=
LLM_TEMPERATURE=

# --- STEP 006: Embedding / Vector ---
# EMBEDDING_PROVIDER=mock  또는  EMBEDDING_PROVIDER=openai
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBEDDING_DIM=
EMBEDDING_TIMEOUT_SEC=
MILVUS_COLLECTION=

# --- STEP 007: RSS Collector ---
# per-source feedparser fetch timeout (seconds)
RSS_COLLECTOR_FETCH_TIMEOUT_SEC=15
# path to JSON sources config; empty = use DEFAULT_SOURCES
RSS_SOURCES_CONFIG_PATH=
# User-Agent header sent to RSS feeds
RSS_COLLECTOR_USER_AGENT=event-intelligence/0.7 (+ei)
# set to "1" to enable live RSS smoke tests
RUN_RSS_LIVE_SMOKE=

# --- STEP 008A: LangSmith opt-in smoke ---
# set to "1" to run LangSmith real-send smoke (requires LANGSMITH_API_KEY)
RUN_LANGSMITH_SMOKE=

# --- STEP 008C: Admin Auth ---
# Leave empty in dev to allow all admin calls without auth (prints WARNING at startup).
# Set a strong random string in prod to enforce X-Admin-Token header on all admin/internal endpoints.
ADMIN_API_TOKEN=

# --- STEP 008C: Reconciler script (scripts/reconcile_stuck_once.py) ---
BACKEND_INTERNAL_URL=http://localhost:8000
RECONCILER_BEFORE_SECONDS=600
RECONCILER_LIMIT=100
# true = inspect only (default), false = actually mark stuck rows as failed
RECONCILER_DRY_RUN=true

# --- STEP 009: OpenSearch Keyword Search ---
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_EVENT_INDEX=event_cards
# --- STEP 009: Reindex script (scripts/reindex_opensearch_once.py) ---
REINDEX_LIMIT=1000
# true = count only (default), false = actually index into OpenSearch
REINDEX_DRY_RUN=true

# --- STEP 010: Frontend ---
# Browser-visible base URL of the backend API (build-time inline for NEXT_PUBLIC_*)
# In dev: http://localhost:8000 (default). In prod: set to your public API domain.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Comma-separated allowed origins for backend CORS
# Default: http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- STEP 011: Docker internal API base URL ---
# Internal URL used by Next.js server-side to call backend (container-to-container).
# In Docker: http://backend:8000. Outside Docker (dev local): http://localhost:8000
INTERNAL_API_BASE_URL=http://backend:8000
