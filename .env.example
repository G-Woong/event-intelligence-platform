# .env.example — 실값 없음, 키 이름만 기재
# 복사: cp .env.example .env  후 실값 채우기

# --- STEP 001: LangSmith 관측 ---
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# --- STEP 001: OpenAI ---
OPENAI_API_KEY=

# --- STEP 001: Vector Store (Milvus) ---
MILVUS_HOST=
MILVUS_PORT=

# --- STEP 001: Redis ---
REDIS_URL=

# --- STEP 004: PostgreSQL ---
DATABASE_URL=

# --- STEP 005: LLM 설정 ---
# LLM_PROVIDER=mock  또는  LLM_PROVIDER=openai
LLM_PROVIDER=
LLM_MODEL=
LLM_TIMEOUT_SEC=
LLM_MAX_TOKENS=
LLM_TEMPERATURE=

# --- STEP 006: Embedding / Vector ---
# EMBEDDING_PROVIDER=mock  또는  EMBEDDING_PROVIDER=openai
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBEDDING_DIM=
EMBEDDING_TIMEOUT_SEC=
MILVUS_COLLECTION=

# --- STEP 007: RSS Collector ---
# per-source feedparser fetch timeout (seconds)
RSS_COLLECTOR_FETCH_TIMEOUT_SEC=15
# path to JSON sources config; empty = use DEFAULT_SOURCES
RSS_SOURCES_CONFIG_PATH=
# User-Agent header sent to RSS feeds
RSS_COLLECTOR_USER_AGENT=event-intelligence/0.7 (+ei)
# set to "1" to enable live RSS smoke tests
RUN_RSS_LIVE_SMOKE=

# --- STEP 008A: LangSmith opt-in smoke ---
# set to "1" to run LangSmith real-send smoke (requires LANGSMITH_API_KEY)
RUN_LANGSMITH_SMOKE=

# --- STEP 008C: Admin Auth ---
# Leave empty in dev to allow all admin calls without auth (prints WARNING at startup).
# Set a strong random string in prod to enforce X-Admin-Token header on all admin/internal endpoints.
ADMIN_API_TOKEN=

# --- STEP 008C: Reconciler script (scripts/reconcile_stuck_once.py) ---
BACKEND_INTERNAL_URL=http://localhost:8000
RECONCILER_BEFORE_SECONDS=600
RECONCILER_LIMIT=100
# true = inspect only (default), false = actually mark stuck rows as failed
RECONCILER_DRY_RUN=true

# --- STEP 009: OpenSearch Keyword Search ---
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_EVENT_INDEX=event_cards
# --- STEP 009: Reindex script (scripts/reindex_opensearch_once.py) ---
REINDEX_LIMIT=1000
# true = count only (default), false = actually index into OpenSearch
REINDEX_DRY_RUN=true

# --- STEP 010: Frontend ---
# Browser-visible base URL of the backend API (build-time inline for NEXT_PUBLIC_*)
# In dev: http://localhost:8000 (default). In prod: set to your public API domain.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Comma-separated allowed origins for backend CORS
# Default: http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- STEP 011: Docker internal API base URL ---
# Internal URL used by Next.js server-side to call backend (container-to-container).
# In Docker: http://backend:8000. Outside Docker (dev local): http://localhost:8000
INTERNAL_API_BASE_URL=http://backend:8000

# ============================================================
# Ingestion Layer — Data Source API Keys
# 값 없이 키 이름만 기재. cp .env.example .env 후 실값 채우기.
# 주의: 주석 없는 일반 문장을 넣으면 check_env_hygiene.py가 UNCOMMENTED_PROSE 경고를 발생시킨다.
#       모든 주석 줄은 반드시 '#'으로 시작해야 한다.
# ============================================================

# --- Naver Search API (blog + news) ---
# 정식 키명: NAVER_CLIENT_ID / NAVER_CLIENT_SECRET
# alias 허용: CLIENT_ID / CLIENT_SECRET (env_loader.py alias 해석)
# 발급: https://developers.naver.com/apps/#/register
# 무료: 일 25,000 calls/서비스
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# legacy alias (env_loader가 NAVER_CLIENT_ID/SECRET으로 해석)
CLIENT_ID=
CLIENT_SECRET=

# --- YouTube Data API v3 ---
# 발급: https://console.cloud.google.com/ (YouTube Data API v3 활성화)
# 무료: 10,000 quota units/day
YOUTUBE_API_KEY=

# --- Product Hunt API v2 ---
# 정식 키명: PRODUCT_HUNT_ACCESS_TOKEN
# alias 허용: PRODUCT_HUNT_API_KEY (env_loader.py alias 해석)
# 발급: https://www.producthunt.com/v2/oauth/applications
# 무료: developer token ~1,000 req/day (UNKNOWN 정확값)
PRODUCT_HUNT_ACCESS_TOKEN=

# --- OpenDart (금융감독원 전자공시) ---
# 발급: https://opendart.fss.or.kr (회원가입 후 API key 신청)
# 무료: ~10,000 req/day (UNKNOWN 정확값)
OPENDART_API_KEY=

# --- BOK ECOS (한국은행 경제통계) ---
# 정식 키명: BOK_ECOS_API_KEY
# alias 허용: ECOS_API_KEY (env_loader.py alias 해석)
# 발급: https://ecos.bok.or.kr/api/#/AuthKeyApply
# 무료: UNKNOWN (개인 비상업적 무료로 추정)
BOK_ECOS_API_KEY=
# legacy alias
ECOS_API_KEY=

# --- EIA (미국 에너지정보청) ---
# 발급: https://www.eia.gov/opendata/register.php
# 무료: 5,000 requests/day
EIA_API_KEY=

# --- GCP Service Account (선택적) ---
# 파일 경로만 기재. env_loader는 경로 존재 여부만 확인하며 내용을 절대 읽지 않는다.
# 파일 자체는 .gitignore에 의해 추적 제외 (*service-account*.json, *-key.json).
GOOGLE_APPLICATION_CREDENTIALS=

# ============================================================
# Phase 4 확장 소스 후보 API Keys (implemented: false, 미배포)
# 값 없이 키 이름만 기재. 실사용 전 각 서비스에서 키 발급 필요.
# ============================================================

# --- Search Enrichment ---
# Google Programmable Search: https://developers.google.com/custom-search/v1/overview
# 무료: 100 queries/day; paid $5/1000 after
# 정식 키명: GOOGLE_CUSTOM_SEARCH_API_KEY / GOOGLE_CUSTOM_SEARCH_CX
# alias 허용: GOOGLE_API_KEY / CSE_CX (env_loader.py alias 해석)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=
# legacy alias
GOOGLE_API_KEY=
CSE_CX=

# Serper (Google SERP): https://serper.dev/api-key
# 무료: 2500 free queries (one-time credit)
SERPER_API_KEY=

# Tavily AI Search: https://app.tavily.com
# 무료: 1000 req/month
TAVILY_API_KEY=

# Exa (Neural Search): https://dashboard.exa.ai
# 무료: 1000 req/month
EXA_API_KEY=

# NewsAPI: https://newsapi.org/register
# 무료: 100 req/day (developer plan; no commercial use)
NEWSAPI_API_KEY=

# GNews: https://gnews.io/docs/
# 무료: 100 req/day, 10 articles/request
GNEWS_API_KEY=

# The Guardian: https://open-platform.theguardian.com/access/
# 무료: 5000 calls/day (no commercial redistribution)
GUARDIAN_API_KEY=

# New York Times: https://developer.nytimes.com/
# 무료: 500 req/day (no commercial use without agreement)
NYT_API_KEY=

# --- Market Signal ---
# Finnhub: https://finnhub.io/register
# 무료: 60 req/min; real-time US stocks
FINNHUB_API_KEY=

# Twelve Data: https://twelvedata.com/pricing
# 무료: 800 credits/day
TWELVE_DATA_API_KEY=

# Alpha Vantage: https://www.alphavantage.co/support/#api-key
# 무료: 25 req/day
ALPHA_VANTAGE_API_KEY=

# Polygon.io: https://polygon.io/dashboard/signup
# 무료: unlimited prev-day data; real-time requires paid
POLYGON_API_KEY=

# Coinbase / Binance: public market data, no key required
# (no env key needed)

# --- Domain Signal ---
# 기상청 KMA: https://apihub.kma.go.kr/
# 발급: https://data.go.kr (공공데이터포털)
KMA_API_KEY=

# 한국관광공사 TourAPI: https://api.visitkorea.or.kr/
# 발급: https://data.go.kr
TOUR_API_KEY=

# 국토교통부 ITS: https://www.its.go.kr/opendata/opendataList
ITS_API_KEY=

# 영화진흥위원회 KOBIS: https://www.kobis.or.kr/kobisopenapi/
# 정식 키명: KOFIC_API_KEY (이전 KOBIS_API_KEY에서 변경)
KOFIC_API_KEY=

# TMDB: https://developers.themoviedb.org/
# 무료: ~100 req/hour
TMDB_API_KEY=

# 공연예술통합전산망 KOPIS: https://kopis.or.kr/openApi/restful/pblprfr
KOPIS_API_KEY=

# 알라딘 Open API (TTB): https://www.aladin.co.kr/ttb/wblog/IndividualInfo.aspx
# 개인 사용 무료; 상업적 사용은 별도 계약 필요
ALADIN_TTB_KEY=

# IGDB (Twitch OAuth 필요): https://api-docs.igdb.com/
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# 문화포털: https://www.culture.go.kr/openapi/openApiView.do
# 정식 키명: CULTURE_INFO_KEY (이전 CULTURE_INFO_API_KEY에서 변경)
CULTURE_INFO_KEY=

# SEC EDGAR User-Agent (선택적): https://www.sec.gov/developer
# 미설정 시 event-intelligence/0.7 (+ei) 사용
SEC_USER_AGENT=
