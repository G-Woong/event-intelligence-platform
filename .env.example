# .env.example — 실제 키 값 없이 키 이름만 노출하는 템플릿
# 사용법: 본 파일을 `.env`로 복사한 뒤 실제 값을 채워 사용한다.
# 절대 실제 키 값을 이 파일이나 git에 포함시키지 말 것.

# --- LangSmith (관측) ---
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Milvus ---
MILVUS_HOST=localhost
MILVUS_PORT=19530

# --- Redis (Celery broker / 캐시) ---
REDIS_URL=redis://localhost:6379/0
